# Personal AI Employee — Platinum Tier Environment Variables
# Copy to .env and fill in values for your machine.

# ============================================================
# REQUIRED — Platinum tier will not start without these
# ============================================================

# Agent role: 'cloud' on VM, 'local' on laptop
# Cloud: can only read/triage/draft. Local: full execution with HITL gates.
FTE_ROLE=local

# Absolute path to the Obsidian vault directory
# Local default:  /home/safdarayub/Documents/AI_Employee_Vault
# Cloud default:  /home/ubuntu/AI_Employee_Vault
VAULT_PATH=/home/safdarayub/Documents/AI_Employee_Vault

# Absolute path to the project source code root
PROJECT_ROOT=/home/safdarayub/Desktop/claude/fte

# ============================================================
# OPTIONAL — sensible defaults provided
# ============================================================

# Git sync interval in seconds (default: 60)
GIT_SYNC_INTERVAL_SECONDS=60

# Dry-run mode: 'true' prevents real external actions (default: true)
# Set to 'false' + use --live flag for production
DRY_RUN=true

# Cloud VM host IP (for local reference only; not used by cloud agent)
FTE_CLOUD_HOST=141.145.146.17

# Ralph Wiggum retry limit (default: 15, hard cap: 20)
RALPH_MAX_ITERATIONS=15

# Odoo ERP connection (default: localhost:8069)
ODOO_HOST=localhost
ODOO_PORT=8069

# ============================================================
# SECRETS — these are NEVER synced to git
# Ensure .gitignore and pre-commit hook block these files.
# ============================================================
# ANTHROPIC_API_KEY=sk-...
# GMAIL_CLIENT_ID=...
# GMAIL_CLIENT_SECRET=...
# FACEBOOK_ACCESS_TOKEN=...
# TWITTER_API_KEY=...

# ============================================================
# PRE-COMMIT HOOK INSTALLATION (run once per clone)
# ============================================================
# cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
